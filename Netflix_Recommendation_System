'Release_Date']  = pd.to_datetime(df['Release_Date'], errors='coerce')\ndf['Release_Year']  = df['Release_Date'].dt.year\n\n# ── Fill remaining numeric nulls with median ──────────────────────────────────\ndf['Vote_Average']  = df['Vote_Average'].fillna(df['Vote_Average'].median())\ndf['Vote_Count']    = df['Vote_Count'].fillna(df['Vote_Count'].median())\ndf['Popularity']    = df['Popularity'].fillna(df['Popularity'].median())\n\n# ── Remove duplicates ─────────────────────────────────────────────────────────\ndf = df.drop_duplicates(subset=['Title'], keep='first').reset_index(drop=True)\n\nprint(f'   Cleaned shape: {df.shape}')\nprint(f'   Unique titles: {df[\"Title\"].nunique():,}')\nprint(f'   Null check   : {df[[\"Title\",\"Overview\",\"Genre\"]].isnull().sum().to_dict()}')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-24T10:36:22.278053Z","iopub.execute_input":"2026-03-24T10:36:22.278332Z","iopub.status.idle":"2026-03-24T10:36:22.327132Z","shell.execute_reply.started":"2026-03-24T10:36:22.278307Z","shell.execute_reply":"2026-03-24T10:36:22.325946Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ── Text Cleaning Function ────────────────────────────────────────────────────\ndef clean_text(text):\n    if pd.isna(text):\n        return ''\n    text = text.lower()\n    text = re.sub(r'[^a-zA-Z0-9\\s]', ' ', text)\n    text = re.sub(r'\\s+', ' ', text).strip()\n    return text\n\n# ── Clean Overview & Genre ────────────────────────────────────────────────────\ndf['Overview_Clean'] = df['Overview'].apply(clean_text)\ndf['Genre_Clean'] = df['Genre'].apply(clean_text)\n\n\n# ── Create Genre as space-separated tags (e.g. 'action adventure scifi') ─────\ndf['Genre_Tags'] = df['Genre'].str.replace(', ',' ').str.replace(' ','_').str.lower()\n\n\n# ── Combined Tags column (Genre + Overview + Language) ────────────────────────\ndf['Tags'] = (\n    df['Genre'].fillna('') + ' ' +\n    df['Genre'].fillna('') + ' ' +\n    df['Overview'].fillna('') + ' ' +\n    df['Original_Language'].fillna('')\n             ).apply(clean_text)\n\nprint('Text columns created: ')\nprint(df[['Title','Genre_Tags','Tags']].head(3).to_string())","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-24T10:49:42.194047Z","iopub.execute_input":"2026-03-24T10:49:42.194381Z","iopub.status.idle":"2026-03-24T10:49:42.62038Z","shell.execute_reply.started":"2026-03-24T10:49:42.194358Z","shell.execute_reply":"2026-03-24T10:49:42.619426Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"---\n##  Section 4 — Exploratory Analysis (Quick Overview)","metadata":{}},{"cell_type":"code","source":"fig, axes = plt.subplots(1,3, figsize=(16, 5))\n\n# Rating distribution\naxes[0].hist(df['Vote_Average'], bins=40, color='#E50914',  edgecolor='white', alpha=0.85)\naxes[0].axvline(df['Vote_Average'].mean(), color='white', linestyle='--', lw=2, label=f'Mean: {df[\"Vote_Average\"].mean():.2f}')\naxes[0].set_title('Rating Distribution', fontweight='bold')\naxes[0].set_xlabel('Voting Average')\naxes[0].legend()\n\n# Popularity distribution\np99 = df['Popularity'].quantile(0.99)\naxes[1].hist(df[df['Popularity'] <= p99]['Popularity'], bins=50, color='steelblue', edgecolor='white', alpha=0.85)\naxes[1].set_title('Popularity Distribution (<=99 pct)', fontweight='bold')\naxes[1].set_xlabel('Popularity Score')\n\n# Top 10 genres\ngenre_counts= df['Genre'].str.split(', ').explode().value_counts().head(10)\naxes[2].barh(genre_counts.index[::-1], genre_counts.values[::-1],color=sns.color_palette('tab10',10))\naxes[2].set_title('Top 10 Genres', fontweight='bold')\naxes[2].set_xlabel('Count')\n\nplt.suptitle('Netflix Dataset - Quick Overview', fontsize=15, fontweight='bold', y=1.02)\nplt.tight_layout()\nplt.savefig('/kaggle/working/overview_stats.png',dpi=150, bbox_inches='tight')\nplt.show","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-24T11:20:04.970686Z","iopub.execute_input":"2026-03-24T11:20:04.970985Z","iopub.status.idle":"2026-03-24T11:20:06.029926Z","shell.execute_reply.started":"2026-03-24T11:20:04.970949Z","shell.execute_reply":"2026-03-24T11:20:06.028735Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Scatter: Popularity vs Rating\ndf_plot = df[df['Popularity'] <= df['Popularity'].quantile(0.98)]\n\nfig, ax=plt.subplots(figsize=(10,6))\nsc = ax.scatter(df_plot['Vote_Average'], df_plot['Popularity'], c=df_plot['Vote_Count'], cmap='YlOrRd',\n                alpha=0.4, s=18, edgecolors='none')\nplt.colorbar(sc, ax=ax, label='Vote Count')\nax.set_title('Popularity vs Rating (colored by Vote Count)', fontsize=13, fontweight='bold')\nax.set_xlabel('Vote Average')\nax.set_ylabel('Popularity Score')\nplt.tight_layout()\nplt.savefig('/kaggle/working/popularity_vs_rating.png', dpi=150, bbox_inches='tight')\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-24T11:25:07.241543Z","iopub.execute_input":"2026-03-24T11:25:07.241831Z","iopub.status.idle":"2026-03-24T11:25:07.867188Z","shell.execute_reply.started":"2026-03-24T11:25:07.241809Z","shell.execute_reply":"2026-03-24T11:25:07.866153Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"---\n##  Section 5 — IMDB Weighted Rating (Top Charts)\n\nBefore building the recommendation engines, let's compute a **reliable ranking** using the IMDB Bayesian Weighted Rating formula:\n\n$$WR = \\frac{v}{v+m} \\cdot R + \\frac{m}{v+m} \\cdot C$$\n\nWhere:\n- **v** = number of votes for the movie  \n- **m** = minimum votes required (threshold)  \n- **R** = average rating of the movie  \n- **C** = mean rating across all movies  \n\n> This prevents low-vote movies with perfect scores from ranking unrealistically high.","metadata":{}},{"cell_type":"code","source":"# — IMBD Weighted Rating Formula ──────────────────────────────────────────────\nC = df['Vote_Average'].mean()\nm = df['Vote_Count'].quantile(0.70)\n\nprint(f' IMBD Formula Parameters: ')\nprint(f' C (mean rating         : {C:.2f}')\nprint(f' m (min votes @ 70th%   : {m:.0f}')\n\ndef weighted_rating(row, C=C, m=m):\n    v = row['Vote_Count']\n    R = row['Vote_Average']\n    return (v/ (v+m)) * R + (m / (v+m)) * C\n\ndf['Weighted_Rating'] = df.apply(weighted_rating, axis=1)\n\nprint(f'\\n Weighted Rating computed for all {len(df):,} titles')\nprint(f' Range:{df[\"Weighted_Rating\"].min():.2f} - {df[\"Weighted_Rating\"].max():.2f}')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-24T11:46:22.859835Z","iopub.execute_input":"2026-03-24T11:46:22.860195Z","iopub.status.idle":"2026-03-24T11:46:22.934334Z","shell.execute_reply.started":"2026-03-24T11:46:22.86017Z","shell.execute_reply":"2026-03-24T11:46:22.933486Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ── Top 15 Movies by Weighted Rating ─────────────────────────────────────────\ntop15 = df.nlargest(15, 'Weighted_Rating')[['Title', 'Weighted_Rating', 'Vote_Average', 'Vote_Count', 'Genre']]\ntop15.index = range(1, 16)\nprint(' Top 15 Netflix Titles by IMDB Weighted Rating:')\ntop15","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-24T11:48:16.635418Z","iopub.execute_input":"2026-03-24T11:48:16.63572Z","iopub.status.idle":"2026-03-24T11:48:16.659114Z","shell.execute_reply.started":"2026-03-24T11:48:16.635697Z","shell.execute_reply":"2026-03-24T11:48:16.657841Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"fig, ax = plt.subplots(figsize=(12, 7))\ncolors = ['#E50914' if i < 3 else '#831010' if i < 7 else '#4a0000'\n          for i in range(15)]\n\nbars = ax.barh(top15['Title'][::-1], top15['Weighted_Rating'][::-1],\n               color=colors[::-1], edgecolor='none', height=0.7)\n\nfor bar, val in zip(bars, top15['Weighted_Rating'][::-1]):\n    ax.text(bar.get_width() + 0.02, bar.get_y() + bar.get_height()/2,\n            f'{val:.2f}', va='center', fontsize=9, fontweight='bold')\n\nax.set_title('Top 15 Netflix Titles — IMDB Weighted Rating', fontsize=14, fontweight='bold')\nax.set_xlabel('Weighted Rating Score')\nax.set_xlim(0, top15['Weighted_Rating'].max() * 1.12)\nax.axvline(C, color='gray', linestyle='--', linewidth=1, label=f'Dataset Mean: {C:.2f}')\nax.legend()\nplt.tight_layout()\nplt.savefig('/kaggle/working/top15_weighted_rating.png', dpi=150, bbox_inches='tight')\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-24T11:49:03.351345Z","iopub.execute_input":"2026-03-24T11:49:03.351686Z","iopub.status.idle":"2026-03-24T11:49:03.908789Z","shell.execute_reply.started":"2026-03-24T11:49:03.351651Z","shell.execute_reply":"2026-03-24T11:49:03.907637Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ── Top 10 by Popularity ──────────────────────────────────────────────────────\ntop10_pop = df.nlargest(10, 'Popularity')[['Title', 'Popularity', 'Vote_Average', 'Genre']]\ntop10_pop.index = range(1, 11)\nprint(' Top 10 Most Popular Titles:')\ntop10_pop","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-24T11:49:27.516648Z","iopub.execute_input":"2026-03-24T11:49:27.516959Z","iopub.status.idle":"2026-03-24T11:49:27.537213Z","shell.execute_reply.started":"2026-03-24T11:49:27.516931Z","shell.execute_reply":"2026-03-24T11:49:27.536379Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"---\n##  Section 6 — TF-IDF Vectorization (Theory + Implementation) Engine 1\n\n###  What is TF-IDF?\n\n**TF-IDF** (Term Frequency–Inverse Document Frequency) is a numerical statistic that reflects how important a word is to a document in a collection.\n\n$$TF\\text{-}IDF(t, d) = TF(t, d) \\times IDF(t)$$\n\n| Component | Formula | Meaning |\n|-----------|---------|----------|\n| **TF(t, d)** | count(t in d) / total words in d | How often term *t* appears in document *d* |\n| **IDF(t)** | log(N / df(t)) | How rare term *t* is across all documents |\n\n- **High TF-IDF** → word is frequent in this doc but rare across all docs → very descriptive\n- **Low TF-IDF** → common words like \"the\", \"is\", \"a\" → filtered out as stop words\n\n###  What is Cosine Similarity?\n\n$$\\cos(\\theta) = \\frac{A \\cdot B}{\\|A\\| \\|B\\|}$$\n\n- Measures the **angle** between two vectors (movie plot embeddings)\n- Score of **1.0** = identical direction (very similar)\n- Score of **0.0** = perpendicular (completely different)\n- Score of **-1.0** = opposite (no shared content)","metadata":{}},{"cell_type":"code","source":"# ── ENGINE 1: TF-IDF on Movie Overview ───────────────────────────────────────\nprint('Building TF-IDF matrix on Movies Overview...')\n\ntfidf_overview = TfidfVectorizer(\n    stop_words='english',\n    max_features=50000,\n    ngram_range=(1,2),\n    min_df=2,\n    sublinear_tf=True\n)\n\ntfidf_matrix_overview = tfidf_overview.fit_transform(df['Overview_Clean'])\n\nprint(f' TF-IDF Matrix Shape : {tfidf_matrix_overview.shape}')\nprint(f' Rows = {tfidf_matrix_overview.shape[0]:,} movies')\nprint(f' Cols = {tfidf_matrix_overview.shape[1]:,} features (terms)')\nprint(f' Sparsity = {(1 - tfidf_matrix_overview.nnz / (tfidf_matrix_overview.shape[0]*tfidf_matrix_overview.shape[1]))*100:.1f}%')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-24T12:06:49.905337Z","iopub.execute_input":"2026-03-24T12:06:49.905605Z","iopub.status.idle":"2026-03-24T12:06:51.089742Z","shell.execute_reply.started":"2026-03-24T12:06:49.905582Z","shell.execute_reply":"2026-03-24T12:06:51.088151Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ── Visualise top TF-IDF terms ────────────────────────────────────────────────\nfeature_names = tfidf_overview.get_feature_names_out()\ntfidf_scores  = np.asarray(tfidf_matrix_overview.mean(axis=0)).ravel()\ntop_terms_idx = tfidf_scores.argsort()[::-1][:20]\n\nfig, ax = plt.subplots(figsize=(12, 5))\nax.bar(range(20), tfidf_scores[top_terms_idx],\n       color=sns.color_palette('flare', 20), edgecolor='whit