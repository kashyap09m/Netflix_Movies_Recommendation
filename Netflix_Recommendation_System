vie, cosine_sim_hybrid,   indices_hybrid,   df, top_n=10, show_score=False)\n    \n    if r1 is not None and r2 is not None and r3 is not None:\n        results.append({\n            'Movie'        : movie,\n            'Engine1_Overlap%' : genre_overlap_score(movie, r1, df),\n            'Engine2_Overlap%' : genre_overlap_score(movie, r2, df),\n            'Engine3_Overlap%' : genre_overlap_score(movie, r3, df),\n        })\n\nquality_df = pd.DataFrame(results)\nprint(' Genre Overlap Score (% of recommendations sharing genre with input):')\nprint(quality_df.to_string(index=False))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-24T13:03:55.333566Z","iopub.execute_input":"2026-03-24T13:03:55.333833Z","iopub.status.idle":"2026-03-24T13:03:55.483755Z","shell.execute_reply.started":"2026-03-24T13:03:55.33381Z","shell.execute_reply":"2026-03-24T13:03:55.48266Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ── Visualise quality comparison ──────────────────────────────────────────────\nfig, ax = plt.subplots(figsize=(12, 5))\n\nx = np.arange(len(quality_df))\nw = 0.25\n\nax.bar(x - w, quality_df['Engine1_Overlap%'], width=w, label='Engine 1 (Plot)',\n       color='#4C72B0', edgecolor='white')\nax.bar(x,     quality_df['Engine2_Overlap%'], width=w, label='Engine 2 (Genre)',\n       color='#2ca02c', edgecolor='white')\nax.bar(x + w, quality_df['Engine3_Overlap%'], width=w, label='Engine 3 (Hybrid)',\n       color='#E50914', edgecolor='white')\n\nax.set_xticks(x)\nax.set_xticklabels([m[:20] + '...' if len(m) > 20 else m for m in quality_df['Movie']],\n                   rotation=15, ha='right')\nax.set_ylim(0, 115)\nax.set_ylabel('Genre Overlap %')\nax.set_title(' Recommendation Quality — Genre Overlap Score by Engine', fontsize=13, fontweight='bold')\nax.legend()\nax.axhline(100, color='gray', linestyle='--', linewidth=0.8)\n\nfor container in ax.containers:\n    ax.bar_label(container, fmt='%.0f%%', padding=2, fontsize=9)\n\n